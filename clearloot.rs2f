group: Hide items on other boats
*/
#define MERCHANT_SHIPWRECK_STATE true

#define SALVAGE_AREA_HIDE [3838,6432,0,3896,6465,3]

rule ((ownership:2) && area:SALVAGE_AREA_HIDE && name:OTHER_BOAT_HIDE && gevalue:<OTHER_BOAT_VALUE) {hidden = true;}
rule ((ownership:2) && area:SALVAGE_AREA_HIDE && name:SMALL_SHIPWRECKS_HIDE && SMALL_SHIPWRECKS_STATE && gevalue:<OTHER_BOAT_VALUE) {hidden = true;}
rule ((ownership:2) && area:SALVAGE_AREA_HIDE && name:FISHERMANS_SHIPWRECKS_HIDE && FISHERMANS_SHIPWRECKS_STATE && gevalue:<OTHER_BOAT_VALUE) {hidden = true;}
rule ((ownership:2) && area:SALVAGE_AREA_HIDE && name:BARRACUDA_SHIPWRECK_HIDE && BARRACUDA_SHIPWRECK_STATE && gevalue:<OTHER_BOAT_VALUE) {hidden = true;}
rule ((ownership:2) && area:SALVAGE_AREA_HIDE && name:LARGE_SHIPWRECKS_HIDE && LARGE_SHIPWRECKS_STATE && gevalue:<OTHER_BOAT_VALUE) {hidden = true;}
rule ((ownership:2) && area:SALVAGE_AREA_HIDE && name:PIRATE_SHIPWRECK_HIDE && PIRATE_SHIPWRECK_STATE && gevalue:<OTHER_BOAT_VALUE) {hidden = true;}
rule ((ownership:2) && area:SALVAGE_AREA_HIDE && name:MERCENARY_SHIPWRECK_HIDE && MERCENARY_SHIPWRECK_STATE && gevalue:<OTHER_BOAT_VALUE) {hidden = true;}
rule ((ownership:2) && area:SALVAGE_AREA_HIDE && name:FREMENNIK_SHIPWRECK_HIDE && FREMENNIK_SHIPWRECK_STATE && gevalue:<OTHER_BOAT_VALUE) {hidden = true;}
rule ((ownership:2) && area:SALVAGE_AREA_HIDE && name:MERCHANT_SHIPWRECK_HIDE && MERCHANT_SHIPWRECK_STATE && gevalue:<OTHER_BOAT_VALUE) {hidden = true;}


