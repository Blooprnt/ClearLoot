/* #region [1] untradeable */
/*@ define:module:untradeables
---
name: Untradeables
description: |
  Enabled by default is all untradeables show as white text as opposed to hidden. You can add which untradeables to hide by adding them to the text box or disabling this all together
*/

/*@ define:input:untradeables
type: boolean
label: They appear white
*/
#define UNTRADABLE_SHOW_ENABLED true

/*@ define:input:untradeables
type: boolean
label: Some are transparent
*/
#define UNTRADABLE_SHOW_TRANSPARENT_ENABLED true

/*@ define:input:untradeables
type: boolean
label: Some are hidden, but clickable
*/
#define UNTRADABLE_HIDE_CLICKABLE_ENABLED true

/*@ define:input:untradeables
type: stringlist
label: Untradeables to make less transparent
*/
#define UNTRADABLE_SHOW_TRANSPARENT_ITEMS ["Queen help book","Damaged armour","Tortugan scute","Sea shell","Fossilised skull"]

/*@ define:input:untradeables
type: stringlist
label: Untradeables to hide but keep clickable
*/
#define UNTRADABLE_HIDE_CLICKABLE_ITEMS ["Broken arrow"]

/*@ define:input:untradeables
type: stringlist
label: Untradeables to fully hide
*/
#define UNTRADABLE_HIDE_ITEMS ["Stymphike carcass","Broken glass"]

/*@ define:input:untradeables
type: style
label: Style
exampleItem: Untradeable
*/
#define UNTRADABLE_SHOW_CUSTOMSTYLE textColor = "#FFffffff";showDespawn = true;

/*@ define:input:untradeables
type: style
label: Style
exampleItem: Broken Glasss
*/
#define UNTRADABLE_SHOW_TRANSPARENT_CUSTOMSTYLE textColor = "#6e919191";textAccentColor = "#6e000000";menuTextColor = "#FF787878";textAccent = 1;fontType = 1;showDespawn = false;

/*@ define:input:untradeables
type: style
label: Style
exampleItem: Hidden
*/
#define UNTRADABLE_HIDE_CLICKABLE_CUSTOMSTYLE textColor = "#00ffffff";backgroundColor = "#00000000";borderColor = "#00000000";textAccentColor = "#00000000";textAccent = 3;showDespawn = false;

apply (tradeable: false && UNTRADABLE_SHOW_ENABLED) {
    hidden = false;
    UNTRADABLE_SHOW_CUSTOMSTYLE
}

apply (tradeable: false && UNTRADABLE_SHOW_TRANSPARENT_ENABLED && name:UNTRADABLE_SHOW_TRANSPARENT_ITEMS) {
    hidden = false;
    UNTRADABLE_SHOW_TRANSPARENT_CUSTOMSTYLE
}

apply (tradeable: false && UNTRADABLE_HIDE_CLICKABLE_ENABLED && name:UNTRADABLE_HIDE_CLICKABLE_ITEMS) {
    hidden = false;
    UNTRADABLE_HIDE_CLICKABLE_CUSTOMSTYLE
}

apply (name:UNTRADABLE_HIDE_ITEMS) { 
    hidden = true; 
}
