*/
#define HUNTER_TOOLS_UNHIDE_LIST ["Barb-tail harpoon","Hunters' crossbow","Hunters' sunlight crossbow","Hunter's spear","Bird snare","Box trap","Butterfly net","Falconer's glove","Fish chunks","Hunter kit (spell)","Imp-in-a-box*","Unlit torch","Lit torch","Magic box","Noose wand","Rabbit snare","Teasing stick","Impling jar","Butterfly jar","Small fishing net","Rope","Stymphike feather"]

/*@ define:input:unhide_skilling
type: stringlist
label: Unhide agility skilling tools
*/
#define AGILITY_TOOLS_UNHIDE_LIST ["Mark of grace"]

/*@ define:input:unhide_skilling
type: stringlist
label: Unhide (No Text)
*/
#define UNHIDE_NOTEXT_LIST ["Araxyte venom sac"]

/*@ define:input:unhide_skilling
type: stringlist
label: Unhide other items
*/
#define OTHER_UNHIDE_LIST []

/*@ define:input:unhide_skilling
type: boolean
label: Hunter Unhide Enabled
*/
#define HUNTER_TOOLS_UNHIDE_ENABLE true

/*@ define:input:unhide_skilling
type: boolean
label: Agility Unhide Enabled
*/
#define AGILITY_TOOLS_UNHIDE_ENABLE true

/*@ define:input:unhide_skilling
type: boolean
label: Other Unhide Enabled
*/
#define OTHER_UNHIDE_ENABLE true

/*@ define:input:unhide_skilling
type: boolean
label: Unhide (No Text)
*/
#define UNHIDE_NOTEXT_ENABLE true

/*@ define:input:unhide_skilling
type: style
label: Unhide hunter skilling tools
*/
#define HUNTER_TOOLS_UNHIDE_CUSTOMSTYLE hidden = false;textColor = "#FFffffff";borderColor = "#40ffffff";textAccentColor = "#FF000000";lootbeamColor = "#FFffffff";menuTextColor = "#FFff930b";

/*@ define:input:unhide_skilling
type: style
label: Unhide agility skilling tools
*/
#define AGILITY_TOOLS_UNHIDE_CUSTOMSTYLE hidden = false;textColor = "#ffd42d17";backgroundColor = "#75cdaf04";borderColor = "#ff001d1d";textAccentColor = "#FF000000";lootbeamColor = "#FF225a22";menuTextColor = "#FFff930b";textAccent = 1;fontType = 1;showDespawn = true;notify = true;

/*@ define:input:unhide_skilling
type: style
label: Unhide (No Text)
*/
#define NOTEXT_UNHIDE_CUSTOMSTYLE hidden = false;textColor = "#00ffffff";borderColor = "#00ffffff";textAccentColor = "#00ffffff";textAccent = 3;fontType = 1;showDespawn = false;

/*@ define:input:unhide_skilling
type: style
label: Unhide other items
*/
#define OTHER_UNHIDE_CUSTOMSTYLE hidden = false;textColor = "#FFffffff";borderColor = "#40ffffff";textAccentColor = "#FFffffff";lootbeamColor = "#FFffffff";menuTextColor = "#FFff930b";textAccent = 1;fontType = 1;showDespawn = true;



apply ((ownership:1) && HUNTER_TOOLS_UNHIDE_ENABLE && name:HUNTER_TOOLS_UNHIDE_LIST) {
    HUNTER_TOOLS_UNHIDE_CUSTOMSTYLE
}

apply (AGILITY_TOOLS_UNHIDE_ENABLE && name:AGILITY_TOOLS_UNHIDE_LIST) {
    AGILITY_TOOLS_UNHIDE_CUSTOMSTYLE
}

apply (UNHIDE_NOTEXT_ENABLE && name:UNHIDE_NOTEXT_LIST) {
    NOTEXT_UNHIDE_CUSTOMSTYLE
}

apply (OTHER_UNHIDE_ENABLE && name:OTHER_UNHIDE_LIST) {
    OTHER_UNHIDE_CUSTOMSTYLE
}
